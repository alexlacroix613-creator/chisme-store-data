<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.siempre.chisme-locator-refresh</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/optimus/chisme-store-data/scripts/refresh.sh</string>
  </array>
  <key>WorkingDirectory</key><string>/Users/optimus/chisme-store-data</string>
  <!-- Weekly: Monday 06:00 local (Mountain Time on Optimus) -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key><integer>1</integer>
    <key>Hour</key><integer>6</integer>
    <key>Minute</key><integer>0</integer>
  </dict>
  <key>StandardOutPath</key><string>/Users/optimus/chisme-store-data/launchd.out</string>
  <key>StandardErrorPath</key><string>/Users/optimus/chisme-store-data/launchd.err</string>
</dict>
</plist>
